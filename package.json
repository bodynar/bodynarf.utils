{
    "name": "@bodynarf/utils",
    "version": "1.8.1",
    "author": {
        "name": "Artem",
        "email": "bodynar@gmail.com"
    },
    "license": "MIT",
    "repository": {
        "url": "https://github.com/bodynar/bodynarf.utils",
        "type": "git"
    },
    "bugs": {
        "url": "https://github.com/bodynar/bodynarf.utils/issues",
        "email": "bodynar@gmail.com"
    },
    "keywords": [
        "js",
        "javascript",
        "ts",
        "typescript",
        "function",
        "common",
        "utilities"
    ],
    "main": "./index.js",
    "types": "./index.d.ts",
    "scripts": {
        "build": "tsup",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "prepublish": "npm run test:run && npm run build && npm pack --pack-destination dist",
        "publish": "npm run test:run && npm run build && npm publish --access=public"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^0.34.0",
        "copyfiles": "^2.4.1",
        "jsdom": "^26.1.0",
        "tsup": "^8.5.1",
        "typescript": "^5.0.2",
        "vitepress": "^1.6.4",
        "vitest": "^0.34.0"
    }
}
